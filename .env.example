GOBROKER_PATH=/Users/dilraj.putra/Documents/alpaca/gobroker
GH_REPO=alpacahq/gobroker

# Local Ollama (no cloud). Install Ollama.app + pull at least one chat model + the embed model.
#   ollama pull qwen2.5-coder:7b nomic-embed-text   (recommended on M-series, 16GB+ RAM)
#   ollama pull llama3.2:3b nomic-embed-text        (lighter fallback, terser narrative)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

VECTOR_DB=/tmp/codemap-vectors.sqlite
