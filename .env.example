GOBROKER_PATH=/Users/dilraj.putra/Documents/alpaca/gobroker
GH_REPO=alpacahq/gobroker

# Local Ollama (no cloud). Install Ollama.app + pull at least one chat model + the embed model.
#   ollama pull qwen2.5-coder:3b nomic-embed-text   (recommended — ~10s narrative on Metal GPU, 16GB M-series)
#   ollama pull qwen2.5-coder:7b nomic-embed-text   (higher quality but CPU-bound on 16GB RAM; ~60s narrative)
#   ollama pull llama3.2:3b nomic-embed-text        (fastest but weaker on code/JSON)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

VECTOR_DB=/tmp/codemap-vectors.sqlite
